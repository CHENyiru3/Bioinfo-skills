{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tool_ref.schema.json",
  "title": "Tool Reference",
  "type": "object",
  "required": ["id", "kind", "package_ref", "api_entrypoint", "method_family"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "kind": { "const": "tool_ref" },
    "package_ref": { "type": "string", "minLength": 1 },
    "api_entrypoint": { "type": "string", "minLength": 1 },
    "method_family": { "type": "string" },
    "source_url": { "type": "string" },
    "source_urls": { "type": "array", "items": { "type": "string" } },
    "source_version": { "type": "string" },
    "source_accessed_at": { "type": "string" },
    "source_local_paths": { "type": "array", "items": { "type": "string" } },
    "distillation_status": {
      "enum": ["placeholder", "distilled", "verified", "needs_version_check", "unknown"]
    },
    "state_in": { "type": ["array", "object", "string"] },
    "state_out": { "type": ["array", "object", "string"] },
    "parameters": { "type": ["array", "object", "string"] },
    "caveats": { "type": ["array", "object", "string"] },
    "compatible_adapters": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
